{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "validate-web-build",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/d",
				"/c",
				"cd /d c:\\Users\\keith\\MoneyGeneratorApp\\web && call npm.cmd run build"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "validate-server-tests",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/d",
				"/c",
				"cd /d c:\\Users\\keith\\MoneyGeneratorApp\\server && set CI=1 && call npm.cmd test -- --runInBand --watchAll=false"
			],
			"isBackground": false,
			"group": "test"
		},
		{
			"label": "release budget build",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"build:budget"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "server dependency audit",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"audit",
				"--json",
				"--prefix",
				"server"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "test"
		}
	]
}