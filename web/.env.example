# Environment Variables for Web App

# Backend API URL (update for production)
VITE_API_URL=http://localhost:4000

# Plaid Integration (set in Netlify dashboard for production)
VITE_PLAID_ENV=sandbox

# Analytics (optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PLAID=true
